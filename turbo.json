{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": [".env", ".env.local", ".nvmrc", "tsconfig*.json"],
  "globalEnv": ["NODE_ENV", "CI"],
  "tasks": {
    "assets": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build", "assets"],
      "outputs": ["dist/**", ".output/**", ".vinxi/**", ".nitro/**"],
      "env": ["*_REMOTE_URL", "*_PORT", "*_BASE", "PORTFOLIO_PORT"]
    },
    "dev": {
      "dependsOn": ["assets"],
      "cache": false,
      "persistent": true
    },
    "preview": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "//#lint": {
      "inputs": [
        "eslint.config.mjs",
        "apps/**/*.{ts,tsx,js,mjs,cjs}",
        "packages/**/*.{ts,tsx,js,mjs,cjs}"
      ]
    },
    "//#format:check": {
      "inputs": [
        ".prettierrc.json",
        ".prettierignore",
        "**/*.{ts,tsx,js,mjs,cjs,json,css,md,yml,yaml,html}"
      ]
    },
    "//#test": {
      "inputs": ["vitest.config.ts", "packages/**/*.{ts,tsx}", "apps/**/*.{ts,tsx}"]
    }
  }
}
