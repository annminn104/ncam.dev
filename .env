# ncam monorepo — non-secret configuration (committed).
#
# Precedence (highest first): real environment (shell / docker / CI) > .env.local
# > .env. Local, machine-specific overrides go in `.env.local` (gitignored).
# In Docker these are overridden by build args (see Dockerfile / docker-compose).
#
# NEVER put secrets here — use `.env.local` / `.env.*.local` for those.

# ── Dev + preview ports ────────────────────────────────────────────────
PORTFOLIO_PORT=9000
TOONHUB_PORT=9001
MINDLOOP_PORT=9002
IMMERSIVE_OCEAN_PORT=9003

# ── Federated remote entry URLs (the host loads these) ──────────────────
# Local defaults. In Docker these are overridden with *.localhost hostnames so
# the same URL resolves for the browser and for server-side (SSR) resolution.
TOONHUB_REMOTE_URL=http://localhost:9001/remoteEntry.js
MINDLOOP_REMOTE_URL=http://localhost:9002/remoteEntry.js
IMMERSIVE_OCEAN_REMOTE_URL=http://localhost:9003/remoteEntry.js

# ── Per-remote public base path (default "/") ───────────────────────────
# TOONHUB_BASE=/
# MINDLOOP_BASE=/
# IMMERSIVE_OCEAN_BASE=/
