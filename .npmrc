# pnpm settings for this workspace. Most match pnpm's own defaults — kept
# explicit so behaviour is documented and stable across pnpm upgrades.

# Install missing peer dependencies automatically.
auto-install-peers=true

# Don't fail the whole install on a peer-range mismatch (this repo intentionally
# runs some bleeding-edge versions, e.g. Vite 8 / rolldown).
strict-peer-dependencies=false

# When several packages depend on different versions of the same peer, dedupe to
# the version already required elsewhere — fewer duplicate installs.
dedupe-peer-dependents=true

# Resolve to the highest version allowed by ranges (deterministic with the lockfile).
resolution-mode=highest
